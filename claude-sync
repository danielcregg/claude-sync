#!/usr/bin/env bash
# claude-sync — Sync Claude Code settings, skills, and config across machines
# https://github.com/danielcregg/claude-sync
# MIT License — Daniel Cregg

set -euo pipefail

VERSION="1.0.0"
CLAUDE_DIR="${CLAUDE_HOME:-$HOME/.claude}"
REPO_NAME="claude-sync-config"
GITIGNORE_MARKER="# managed by claude-sync"

# Colors (disable if not a terminal)
if [[ -t 1 ]]; then
  RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'
  BLUE='\033[0;34m'; BOLD='\033[1m'; NC='\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; BLUE=''; BOLD=''; NC=''
fi

log()   { echo -e "${GREEN}[claude-sync]${NC} $*"; }
warn()  { echo -e "${YELLOW}[claude-sync]${NC} $*"; }
error() { echo -e "${RED}[claude-sync]${NC} $*" >&2; }
bold()  { echo -e "${BOLD}$*${NC}"; }

# ─────────────────────────────────────────────
# .gitignore content — the brain of what gets synced
# ─────────────────────────────────────────────
generate_gitignore() {
  cat << 'GITIGNORE'
# managed by claude-sync
# This file controls what gets synced across machines.
# Files NOT listed here will be synced. Files listed here are excluded.

# ── Credentials & Secrets (NEVER sync) ──
.credentials.json
credentials.json
client_secret_*.json
*.pem
*.key

# ── Large ephemeral data (machine-specific) ──
projects/
local/
telemetry/
debug/
cache/
.cache/
usage-data/
sessionStorage/
shell-snapshots/
paste-cache/
file-history/
downloads/

# ── Session-specific (not portable) ──
sessions/
ide/
todos/
tasks/
plans/
*.lock

# ── Stats & analytics ──
statsig/
stats-cache.json

# ── Plugin caches (reinstalled automatically) ──
plugins/cache/
plugins/marketplaces/
plugins/.install-manifests/
plugins/install-counts-cache.json
plugins/data/

# ── Conversation history (large, personal) ──
history.jsonl

# ── Backups (may contain secrets) ──
backups/

# ── Temporary files ──
*.log
*.tmp
*.cache

# ── OS files ──
.DS_Store
Thumbs.db
desktop.ini

# ── Git internals in skill subdirectories ──
skills/*/.git/
GITIGNORE
}

# ─────────────────────────────────────────────
# What DOES get synced (for reference):
#   settings.json          — User preferences, plugins, permissions
#   skills/*/SKILL.md      — Custom skills
#   agents/                — Custom agents
#   commands/              — Custom slash commands
#   hooks/                 — Hook definitions (if stored as files)
#   rules/                 — Custom rules
#   CLAUDE.md              — Global instructions
#   plugins/installed_plugins.json — Plugin list
#   plugins/known_marketplaces.json — Marketplace config
#   plugins/blocklist.json — Blocked plugins
#   keybindings.json       — Key bindings
#   statusline-command.sh  — Status line script
# ─────────────────────────────────────────────

usage() {
  cat << EOF
${BOLD}claude-sync${NC} v${VERSION} — Sync Claude Code config across machines

${BOLD}USAGE${NC}
  claude-sync <command> [options]

${BOLD}COMMANDS${NC}
  init              Set up sync (creates private GitHub repo, initial push)
  push              Commit and push changes to GitHub
  pull              Pull latest config from GitHub
  status            Show what has changed since last sync
  clone [user]      Set up a new machine from an existing sync repo
  doctor            Check sync health and fix common issues
  version           Show version

${BOLD}OPTIONS${NC}
  -m, --message     Custom commit message (for push)
  -f, --force       Force push/pull without confirmation
  -q, --quiet       Minimal output
  -n, --dry-run     Show what would happen without doing it
  -h, --help        Show this help

${BOLD}EXAMPLES${NC}
  claude-sync init                    # First-time setup
  claude-sync push                    # Sync changes to GitHub
  claude-sync push -m "added skill"   # Push with custom message
  claude-sync pull                    # Pull on another machine
  claude-sync clone danielcregg       # New machine setup
  claude-sync status                  # Check what changed

${BOLD}AUTO-SYNC${NC}
  claude-sync init --hook             # Also install auto-sync hook
                                      # (pushes on session end)

EOF
}

# ─────────────────────────────────────────────
# Preflight checks
# ─────────────────────────────────────────────
check_git() {
  if ! command -v git &>/dev/null; then
    error "git is not installed. Install git first."
    exit 1
  fi
}

check_gh() {
  if ! command -v gh &>/dev/null; then
    error "GitHub CLI (gh) is not installed."
    error "Install it: https://cli.github.com/"
    exit 1
  fi
  if ! gh auth status &>/dev/null; then
    error "Not logged into GitHub. Run: gh auth login"
    exit 1
  fi
}

check_claude_dir() {
  if [[ ! -d "$CLAUDE_DIR" ]]; then
    error "Claude directory not found at $CLAUDE_DIR"
    error "Is Claude Code installed?"
    exit 1
  fi
}

is_repo() {
  git -C "$CLAUDE_DIR" rev-parse --git-dir &>/dev/null 2>&1
}

get_gh_user() {
  gh api user --jq '.login' 2>/dev/null
}

# ─────────────────────────────────────────────
# Commands
# ─────────────────────────────────────────────

cmd_init() {
  local install_hook=false
  for arg in "$@"; do
    case "$arg" in
      --hook) install_hook=true ;;
    esac
  done

  check_git
  check_gh
  check_claude_dir

  if is_repo; then
    warn "Already initialized. Use 'claude-sync push' to sync."
    return 0
  fi

  local gh_user
  gh_user=$(get_gh_user)
  log "GitHub user: ${BOLD}$gh_user${NC}"

  # Create private repo if it doesn't exist
  if gh repo view "$gh_user/$REPO_NAME" &>/dev/null; then
    log "Repo $gh_user/$REPO_NAME already exists."
  else
    log "Creating private repo: $gh_user/$REPO_NAME"
    gh repo create "$REPO_NAME" --private \
      --description "Claude Code settings, skills, and config — synced by claude-sync" \
      2>/dev/null
  fi

  # Initialize git in .claude/
  log "Initializing git in $CLAUDE_DIR"
  git -C "$CLAUDE_DIR" init -b main --quiet

  # Write .gitignore
  log "Writing .gitignore (smart defaults)"
  generate_gitignore > "$CLAUDE_DIR/.gitignore"

  # Add remote
  git -C "$CLAUDE_DIR" remote add origin "https://github.com/$gh_user/$REPO_NAME.git" 2>/dev/null || \
    git -C "$CLAUDE_DIR" remote set-url origin "https://github.com/$gh_user/$REPO_NAME.git"

  # Initial commit and push
  log "Committing and pushing..."
  git -C "$CLAUDE_DIR" add -A
  git -C "$CLAUDE_DIR" commit -m "Initial sync via claude-sync v$VERSION" --quiet
  git -C "$CLAUDE_DIR" push -u origin main --quiet 2>/dev/null || \
    git -C "$CLAUDE_DIR" push -u origin main --force --quiet

  # Install hook if requested
  if $install_hook; then
    cmd_install_hook
  fi

  echo ""
  log "Sync initialized!"
  bold "  Repo:   https://github.com/$gh_user/$REPO_NAME (private)"
  bold "  Config: $CLAUDE_DIR"
  echo ""
  log "Commands:"
  echo "  claude-sync push     — push changes"
  echo "  claude-sync pull     — pull on another machine"
  echo "  claude-sync clone            — set up a new machine"
  if ! $install_hook; then
    echo ""
    log "Tip: Run 'claude-sync init --hook' to auto-sync on session end"
  fi
}

cmd_clone() {
  local gh_user="${1:-}"

  # Auto-detect GitHub username if not provided
  if [[ -z "$gh_user" ]]; then
    gh_user=$(get_gh_user 2>/dev/null || true)
    if [[ -z "$gh_user" ]]; then
      error "Could not detect GitHub username."
      error "Usage: claude-sync clone [github-username]"
      exit 1
    fi
    log "Detected GitHub user: ${BOLD}$gh_user${NC}"
  fi

  check_git
  check_gh
  check_claude_dir

  if is_repo; then
    warn "Already initialized. Use 'claude-sync pull' instead."
    return 0
  fi

  local repo="$gh_user/$REPO_NAME"
  if ! gh repo view "$repo" &>/dev/null; then
    error "Repo $repo not found. Did you run 'claude-sync init' on your other machine?"
    exit 1
  fi

  log "Cloning config from $repo..."

  # Init git, add remote, pull
  git -C "$CLAUDE_DIR" init -b main --quiet
  git -C "$CLAUDE_DIR" remote add origin "https://github.com/$repo.git"

  # Fetch and reset to remote (preserves local-only files)
  git -C "$CLAUDE_DIR" fetch origin main --quiet
  git -C "$CLAUDE_DIR" reset origin/main --quiet
  git -C "$CLAUDE_DIR" checkout -- . 2>/dev/null || true
  git -C "$CLAUDE_DIR" branch --set-upstream-to=origin/main main 2>/dev/null || true

  echo ""
  log "Config synced from $repo!"
  log "Your skills, settings, and config are ready."
}

cmd_push() {
  local message="" force=false quiet=false dry_run=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m|--message) message="$2"; shift 2 ;;
      -f|--force) force=true; shift ;;
      -q|--quiet) quiet=true; shift ;;
      -n|--dry-run) dry_run=true; shift ;;
      *) shift ;;
    esac
  done

  check_claude_dir
  if ! is_repo; then
    error "Not initialized. Run 'claude-sync init' first."
    exit 1
  fi

  # Check for changes
  git -C "$CLAUDE_DIR" add -A 2>/dev/null
  if git -C "$CLAUDE_DIR" diff --cached --quiet; then
    $quiet || log "Nothing to sync — already up to date."
    return 0
  fi

  # Show changes
  if ! $quiet; then
    log "Changes to sync:"
    git -C "$CLAUDE_DIR" diff --cached --stat
    echo ""
  fi

  # Dry run
  if $dry_run; then
    log "(dry run — no changes made)"
    return 0
  fi

  # Commit
  local ts
  ts=$(date '+%Y-%m-%d %H:%M')
  message="${message:-sync: $ts}"
  git -C "$CLAUDE_DIR" commit -m "$message" --quiet

  # Push
  git -C "$CLAUDE_DIR" push --quiet
  $quiet || log "Pushed to GitHub."
}

cmd_pull() {
  local force=false quiet=false dry_run=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--force) force=true; shift ;;
      -q|--quiet) quiet=true; shift ;;
      -n|--dry-run) dry_run=true; shift ;;
      *) shift ;;
    esac
  done

  check_claude_dir
  if ! is_repo; then
    error "Not initialized. Run 'claude-sync init' or 'claude-sync clone <user>' first."
    exit 1
  fi

  if $dry_run; then
    git -C "$CLAUDE_DIR" fetch origin main --quiet
    log "Changes available:"
    git -C "$CLAUDE_DIR" diff HEAD..origin/main --stat
    log "(dry run — no changes applied)"
    return 0
  fi

  # Stash local changes, pull, pop
  local had_changes=false
  git -C "$CLAUDE_DIR" add -A 2>/dev/null
  if ! git -C "$CLAUDE_DIR" diff --cached --quiet; then
    had_changes=true
    git -C "$CLAUDE_DIR" stash --quiet
  fi

  git -C "$CLAUDE_DIR" pull --rebase origin main --quiet 2>/dev/null || \
    git -C "$CLAUDE_DIR" pull origin main --quiet

  if $had_changes; then
    git -C "$CLAUDE_DIR" stash pop --quiet 2>/dev/null || \
      warn "Merge conflict — resolve manually in $CLAUDE_DIR"
  fi

  $quiet || log "Pulled latest config."
}

cmd_status() {
  check_claude_dir
  if ! is_repo; then
    error "Not initialized. Run 'claude-sync init' first."
    exit 1
  fi

  git -C "$CLAUDE_DIR" add -A 2>/dev/null

  if git -C "$CLAUDE_DIR" diff --cached --quiet; then
    log "Clean — no changes since last sync."
  else
    log "Changes since last sync:"
    git -C "$CLAUDE_DIR" diff --cached --stat
  fi

  echo ""
  # Show last sync time
  local last_sync
  last_sync=$(git -C "$CLAUDE_DIR" log -1 --format='%ar' 2>/dev/null || echo "never")
  log "Last sync: $last_sync"

  # Show remote status
  git -C "$CLAUDE_DIR" fetch origin main --quiet 2>/dev/null || true
  local ahead behind
  ahead=$(git -C "$CLAUDE_DIR" rev-list --count origin/main..HEAD 2>/dev/null || echo "?")
  behind=$(git -C "$CLAUDE_DIR" rev-list --count HEAD..origin/main 2>/dev/null || echo "?")
  [[ "$ahead" != "0" ]] && log "Ahead of remote by $ahead commit(s) — run 'claude-sync push'"
  [[ "$behind" != "0" ]] && log "Behind remote by $behind commit(s) — run 'claude-sync pull'"
  [[ "$ahead" == "0" && "$behind" == "0" ]] && log "In sync with remote."
}

cmd_doctor() {
  check_claude_dir
  local issues=0

  bold "claude-sync doctor"
  echo ""

  # Check git
  if command -v git &>/dev/null; then
    log "git: $(git --version)"
  else
    error "git: NOT FOUND"
    ((issues++))
  fi

  # Check gh
  if command -v gh &>/dev/null; then
    local gh_user
    gh_user=$(get_gh_user 2>/dev/null || echo "NOT LOGGED IN")
    log "gh: logged in as $gh_user"
  else
    error "gh: NOT FOUND"
    ((issues++))
  fi

  # Check repo
  if is_repo; then
    local remote
    remote=$(git -C "$CLAUDE_DIR" remote get-url origin 2>/dev/null || echo "none")
    log "repo: $remote"
  else
    warn "repo: not initialized"
    ((issues++))
  fi

  # Check .gitignore
  if [[ -f "$CLAUDE_DIR/.gitignore" ]]; then
    if grep -q "$GITIGNORE_MARKER" "$CLAUDE_DIR/.gitignore"; then
      log ".gitignore: managed by claude-sync"
    else
      warn ".gitignore: exists but not managed by claude-sync"
      ((issues++))
    fi
  else
    warn ".gitignore: missing"
    ((issues++))
  fi

  # Check credentials not tracked
  if is_repo; then
    if git -C "$CLAUDE_DIR" ls-files --error-unmatch .credentials.json &>/dev/null 2>&1; then
      error "SECURITY: .credentials.json is tracked by git!"
      error "Run: git -C $CLAUDE_DIR rm --cached .credentials.json"
      ((issues++))
    else
      log "credentials: safely excluded"
    fi
  fi

  # Check what's synced
  if is_repo; then
    local tracked
    tracked=$(git -C "$CLAUDE_DIR" ls-files 2>/dev/null | wc -l)
    log "tracked files: $tracked"
  fi

  echo ""
  if [[ $issues -eq 0 ]]; then
    log "No issues found."
  else
    warn "$issues issue(s) found."
  fi
}

cmd_install_hook() {
  check_claude_dir

  local settings_file="$CLAUDE_DIR/settings.json"
  if [[ ! -f "$settings_file" ]]; then
    error "settings.json not found"
    return 1
  fi

  # Check if hook already exists
  if grep -q "claude-sync push" "$settings_file" 2>/dev/null; then
    log "Auto-sync hook already installed."
    return 0
  fi

  log "Installing auto-sync hook (pushes on session end)..."
  warn "Note: You'll need to manually add the hook to settings.json."
  echo ""
  bold "Add this to your settings.json under \"hooks\":"
  echo ""
  cat << 'HOOK'
"Stop": [{
  "hooks": [{
    "type": "command",
    "command": "claude-sync push -q -m 'auto-sync' 2>/dev/null || true",
    "timeout": 10
  }]
}]
HOOK
  echo ""
  log "Or run: /update-config in Claude Code to add it."
}

# ─────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)     cmd_init "$@" ;;
    push)     cmd_push "$@" ;;
    pull)     cmd_pull "$@" ;;
    status)   cmd_status "$@" ;;
    clone)    cmd_clone "$@" ;;
    doctor)   cmd_doctor "$@" ;;
    hook)     cmd_install_hook "$@" ;;
    version)  echo "claude-sync v$VERSION" ;;
    -h|--help|help) usage ;;
    *)
      error "Unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
